# Локально эти пути можно не задавать: используются соседние папки рабочей области.
# На сервере рекомендуемые значения: /home/bot и /var/lib/echo-dialog-bot/echo.db
VOICE_APP_DIR=
VOICE_DATA_DIR=
ECHO_DATABASE_PATH=

