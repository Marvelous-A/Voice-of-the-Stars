BOT_TOKEN=replace_with_botfather_token
# Отдельный админ-бот отправляет уведомления о новых пользователях, деплоях и ошибках.
ADMIN_BOT_TOKEN=replace_with_admin_bot_token
DATABASE_PATH=echo.db
CALL_BASE_URL=https://meet.jit.si
# Telegram user IDs через запятую, например: 123456789,987654321
ADMIN_IDS=
# Telegram usernames администраторов без @, используются для поиска ID в базе бота
ADMIN_USERNAMES=bimbim2bambam
LOG_LEVEL=INFO

# Бесплатные пользователи могут начинать столько диалогов в сутки.
FREE_DAILY_DIALOG_LIMIT=15

# CKassa: используются те же реквизиты, что и в «Голосе Звёзд».
CKASSA_API_LOGIN=replace_with_same_ckassa_api_login
CKASSA_API_AUTHORIZATION=replace_with_same_ckassa_api_authorization
CKASSA_SERV_CODE=replace_with_same_ckassa_service_code
CKASSA_BASE_URL=https://api2.ckassa.ru/api-shop/rs/open
CKASSA_INVOICE_TTL_MINUTES=60
CKASSA_TIMEOUT_SEC=60
CKASSA_POLL_INTERVAL_SEC=30

# Необязательная реклама для бесплатных пользователей между диалогами.
# Если ECHO_AD_TEXT пуст, реклама не показывается.
ECHO_AD_TEXT=
ECHO_AD_URL=
ECHO_AD_BUTTON_TEXT=Узнать больше
ECHO_AD_DIALOG_INTERVAL=3

# Server-side automatic deployment only
WEBHOOK_SECRET=replace_with_a_long_random_secret
DEPLOY_PORT=9001
GITHUB_REPOSITORY=Marvelous-A/echo-dialog-bot
DEPLOY_BRANCH=main
DEPLOY_NOTIFY_USERNAMES=your_telegram_username
