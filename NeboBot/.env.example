BOT_TOKEN=1234567890:PASTE_TOKEN_FROM_BOTFATHER

# Админ-бот: уведомляет владельца о новых пользователях
ADMIN_BOT_TOKEN=1234567890:PASTE_ADMIN_BOT_TOKEN
ADMIN_ID=123456789

# Источник публикаций
SOURCE_BASE_URL=https://bplarussia.ru
POLL_INTERVAL_SECONDS=60
REQUEST_TIMEOUT_SECONDS=20
REGIONS_CACHE_TTL_SECONDS=600
STATS_CACHE_TTL_SECONDS=30
MAX_HISTORY_PAGES=50

# Локальные данные бота
DATABASE_PATH=data/bpla_region_bot.sqlite3
LOG_LEVEL=INFO

# Необязательно: прокси только для Telegram Bot API
TELEGRAM_PROXY_URL=

# Автоматическое обновление с GitHub (только на сервере)
WEBHOOK_SECRET=replace_with_a_long_random_secret
DEPLOY_PORT=9002
GITHUB_REPOSITORY=Marvelous-A/Nebo-Ryadom-Bot
DEPLOY_BRANCH=main
DEPLOY_NOTIFY_CHAT_IDS=123456789
